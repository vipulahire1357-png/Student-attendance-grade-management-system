# ============================================================
# OnlyStudents — Backend Environment Variables
# Copy this file to .env and fill in real values before running.
# ============================================================

# ── App ─────────────────────────────────────────────────────
APP_NAME="OnlyStudents API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# ── PostgreSQL ───────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:postgresql%40123@localhost:5432/onlystudents
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=f79f3703638995329604327ae4e6ba7f14bc6ba2fda9a19893aab01387dab66e
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ─────────────────────────────────────────────────────
# JSON list of allowed frontend origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── AWS S3 (file uploads) ────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=onlystudents-uploads
AWS_S3_REGION=ap-south-1

# ── AI Engine ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
MATCH_TOP_K=10
MATCH_THRESHOLD=0.5
